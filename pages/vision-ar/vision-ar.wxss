.vision-ar-page {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #000;
}
.camera-feed, .overlay-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
.overlay-canvas {
  z-index: 20;
}
.status-panel {
  position: absolute;
  left: 12px;
  right: 12px;
  bottom: 28px;
  padding: 12px;
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.5);
  z-index: 30;
}
.status-text {
  display: block;
  color: #ffffff;
  font-size: 14px;
  line-height: 22px;
  margin-bottom: 8px;
}
.permission-button {
  width: 100%;
  border: 1px solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
}
