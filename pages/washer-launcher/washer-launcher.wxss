.launcher-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 20rpx;
}
.device-preview {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.preview-img {
  width: 80%;
  border-radius: 16rpx;
}
.actions {
  padding: 20rpx 0;
}
.start-btn {
  width: 60%;
  height: 70rpx;
  background-color: #007aff;
  color: #fff;
  border-radius: 12rpx;
}
